{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "theme": "system",
  "lsp": {
    "rust": {
      "disabled": true
    }
  },
  "experimental": {
    "disable_paste_summary": true
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      ".next/**",
      "coverage/**",
      "target/debug",
      "target/release"
    ]
  },
  "permission": {
    "external_directory": {
      "~/git-worktrees/**": "allow",
      "/tmp": "allow",
      "/tmp/**": "allow",
      "env:$TMPDIR": "allow",
      "env:$TMPDIR/**": "allow",
      "~/.cargo": "allow",
      "~/go": "allow",
      "~/.local/share/mise/installs/go": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-2566a48e-d983-4c43-ab9a-3bf71344ac3e"
      },
      "enabled": true
    },
    "bun": {
      "type": "local",
      "command": [
        "/home/satont/.local/share/mise/shims/bunx",
        "-y",
        "mcp-bun@latest"
      ],
      "environment": {
        "DISABLE_NOTIFICATIONS": "true"
      },
      "enabled": true
    },
    "shadcnVue": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/satont/.local/share/mise/shims/bunx",
        "shadcn-vue@latest",
        "mcp"
      ]
    },
    "playwright": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/satont/.local/share/mise/shims/bunx",
        "@playwright/mcp@latest",
        "--executable-path",
        "/usr/bin/helium-browser"
      ]
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "grepApp": {
    	"type": "remote",
    	"url": "https://mcp.grep.app",
    	"enabled": true
    }
  },
  "plugin": [
    "opencode-mystatus"
  ],
  "command": {
    "mystatus": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification."
    }
  }
}
