{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "theme": "system",
  "autoupdate": true,
  "experimental": {
    "disable_paste_summary": true
  },
  "permission": {
    "external_directory": {
      "~/git-worktrees/**": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-2566a48e-d983-4c43-ab9a-3bf71344ac3e"
      },
      "enabled": true
    },
    "bun": {
      "type": "local",
      "command": [
        "/home/satont/.local/share/mise/shims/bunx",
        "-y",
        "mcp-bun@latest"
      ],
      "environment": {
        "DISABLE_NOTIFICATIONS": "true"
      },
      "enabled": true
    },
    "shadcnVue": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/satont/.local/share/mise/shims/bunx",
        "shadcn-vue@latest",
        "mcp"
      ]
    },
    "playwright": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/satont/.local/share/mise/shims/bunx",
        "@playwright/mcp@latest",
        "--executable-path",
        "/usr/bin/google-chrome-stable"
      ]
    }
  },
  "plugin": [
    "@geeder/opencode-copilot-multi-auth",
    "oh-my-openagent@3.17.12"
  ]
}
